
model Hall {
  id            String    @id @default(cuid())
  name          String
  description   String?
  address       String
  city          String
  state         String
  pincode       String
  latitude      Float?
  longitude     Float?
  capacity      Int
  pricePerDay   Float
  contactNumber String
  email         String?
  isActive      Boolean   @default(true)
  bookings      Booking[]
  images        HallImage[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}





